{
  "name": "create-sds-app-with-batteries-with-fastapi",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev:all": "concurrently \"yarn workspace server dev\" \"yarn workspace client dev\" --names \"🗄️ ,🖥️ \"",
    "formatcheck:all": "yarn workspaces foreach --all -p run formatcheck",
    "typecheck:all": "yarn workspaces foreach --all -p run typecheck",
    "lint:all": "yarn workspaces foreach --all -p run lint",
    "format:all": "yarn workspaces foreach --all -p run format"
  },
  "workspaces": [
    "client",
    "server"
  ],
  "packageManager": "yarn@4.1.1",
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
